@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(_MXL_BUILT_SHARED @MXL_BUILT_SHARED@)

if(NOT _MXL_BUILT_SHARED)
    # Static installs expose these link dependencies through imported
    # targets, so consumers must resolve them when loading the package.
    find_dependency(spdlog CONFIG)
    find_dependency(fmt CONFIG)
endif()

unset(_MXL_BUILT_SHARED)

if(NOT TARGET mxl::mxl)
    include("${CMAKE_CURRENT_LIST_DIR}/mxl-targets.cmake")
endif()
